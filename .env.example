# Required — sign session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=replace-me-with-a-random-32-char-string

# Optional — Anthropic Claude (enables AI question generation, gap analysis, AI hint)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional — HuggingFace free tier (fallback AI + semantic embeddings)
# Free token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Embeddings backend — "local" uses bigram hash (always works); HF_TOKEN enables semantic embeddings automatically
EMBEDDINGS_PROVIDER=local

# Transcription (leave false for demo)
USE_LIVE_TRANSCRIPTION=false

